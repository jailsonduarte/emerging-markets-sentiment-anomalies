)
# Criando o flextable
ft <- flextable(tabela) |>
set_table_properties(width = 1, layout = "autofit") |>
autofit() |>
align(align = "left", part = "all") |>
fontsize(size = 10, part = "all") |>
padding(padding = 4, part = "all")
# Criando o flextable
ft <- flextable(tabela) |>
set_table_properties(width = 1, layout = "autofit") |>
autofit() |>
align(align = "left", part = "all") |>
fontsize(size = 10, part = "all") |>
padding(padding = 4, part = "all")
ft
